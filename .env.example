# Shopify Admin API — use ONE of:
# A) Custom app static token
# SHOPIFY_STORE=your-store.myshopify.com
# SHOPIFY_TOKEN=shpat_xxx
# B) Dev Dashboard app (Client ID + Secret; token ~24h, refreshed automatically)
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional, default 2024-10
# SHOPIFY_API_VERSION=2024-10

# Meta Marketing API
# User access token with ads_read (e.g. from Graph API Explorer).
META_TOKEN=
# Optional: App ID + Secret from App settings → Basic. Each run exchanges META_TOKEN
# for a fresh long-lived token (~60d) so cron does not die when short token expires.
# META_APP_ID=
# META_APP_SECRET=
# Set to 0 to skip exchange and use META_TOKEN as-is (long-lived token required).
# If Meta's exchange endpoint returns 429/500 repeatedly, the pipeline uses META_TOKEN as-is (warning in logs).
# META_FB_EXCHANGE=1
# Campaign-level daily insights (spend, purchases from actions/action_values). Set 0 to skip extra API + META_CAMPAIGNS sheet.
# META_CAMPAIGN_INSIGHTS=1
# Numeric ID or act_123 — script accepts both
AD_ACCOUNT_ID=

# Purchases / Purchase_Value in META_CAMPAIGNS: use ONE Meta action_type (priority list), not a sum of all
# types containing "purchase" (avoids double-count vs Ads Manager). Override order:
# META_PURCHASE_ACTION_TYPES=offsite_conversion.fb_pixel_purchase,purchase,omni_purchase
# Optional: match Ads Manager attribution columns, JSON array:
# META_ACTION_ATTRIBUTION_WINDOWS=["7d_click","1d_view"]

# Meta insights window: either lookback days from today, or explicit since/until (YYYY-MM-DD)
META_LOOKBACK_DAYS=90
# META_TIME_RANGE_SINCE=2026-01-01
# META_TIME_RANGE_UNTIL=2026-04-06

# Google Sheets — use GOOGLE_SHEET_ID or GOOGLE_SHEET_URL (recommended) and/or GOOGLE_SHEET_NAME.
# Opening by id/url needs only Sheets API + share sheet with service account (Editor).
# Opening by name needs Drive API enabled and exact file title match.
# GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# GOOGLE_SHEET_ID=SPREADSHEET_ID
GOOGLE_SHEET_NAME=Your Spreadsheet Name
GOOGLE_CREDS=creds.json
# Alternative (Vercel / CI): paste full JSON — takes precedence over GOOGLE_CREDS
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Vercel Cron: set CRON_SECRET in project env; cron calls GET /cron with Authorization: Bearer <secret>
# CRON_SECRET=

# HTTP retry
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_BASE_SECONDS=1.5

# Report currency label (display) + optional USD columns: USD per 1 unit of local currency
# Example for AUD store: if 1 AUD ≈ 0.65 USD, set USD_PER_LOCAL_UNIT=0.65 (use a current rate).
# Adds Revenue_USD, Product_Cost_USD, …
# REPORT_CURRENCY=AUD
# USD_PER_LOCAL_UNIT=0.65
# Meta ad account currency is usually USD (Graph API "spend"). Default 1 = treat Meta spend as USD
# (Ad_Spend_USD = Ad_Spend; daily merge converts Meta USD → shop currency for ROAS using USD_PER_LOCAL_UNIT).
# Set 0 if your ad account uses the same currency as the shop (e.g. both AUD).
# META_SPEND_IN_USD=1
# SHEETS_FANCY_LAYOUT=1
# Conditional formatting in Sheets: Gross_Profit<0 (red tint), DAILY_SUMMARY Marketing_ROAS<threshold (yellow)
# SHEETS_CONDITIONAL_FORMAT=1
# Default 1.0; set 0 to disable ROAS highlighting only
# SHEETS_ROAS_WARN_BELOW=1

# Supplier unit costs: default is a Google Sheet tab named SUPPLIER_COSTS (created automatically if missing).
# Optional: rename tab via SUPPLIER_COSTS_SHEET_TAB=MyTab
# To use local CSV only (no Sheet tab for pipeline): SUPPLIER_COSTS_FROM_CSV=1
# SUPPLIER_COSTS_SHEET_TAB=SUPPLIER_COSTS

# Optional Google Sheet tab names (defaults shown)
# SHEET_TAB_ORDERS_DB=ORDERS_DB
# SHEET_TAB_ORDER_LEVEL=ORDER_LEVEL
# SHEET_TAB_META_DATA=META_DATA
# SHEET_TAB_META_CAMPAIGNS=META_CAMPAIGNS
# SHEET_TAB_DAILY_SUMMARY=DAILY_SUMMARY
