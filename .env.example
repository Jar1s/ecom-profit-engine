# Shopify Admin API — use ONE of:
# A) Custom app static token
# SHOPIFY_STORE=your-store.myshopify.com
# SHOPIFY_TOKEN=shpat_xxx
# B) Dev Dashboard app (Client ID + Secret; token ~24h, refreshed automatically)
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional, default 2024-10
# SHOPIFY_API_VERSION=2024-10
#
# PAYOUTS_FEES / Shopify Payments REST (`/admin/api/.../shopify_payments/...`): enable Admin API scope
# **read_shopify_payments_payouts** on your Custom app (Develop apps → app → Configuration),
# Save, Install app again, then paste the new Admin API token into SHOPIFY_TOKEN (and redeploy).
# Requires Shopify Payments on the store; merchant approval may apply.

# Meta Marketing API
# User access token with ads_read (e.g. from Graph API Explorer).
META_TOKEN=
# Optional: App ID + Secret from App settings → Basic. Each run exchanges META_TOKEN
# for a fresh long-lived token (~60d) so cron does not die when short token expires.
# META_APP_ID=
# META_APP_SECRET=
# Set to 0 to skip exchange and use META_TOKEN as-is (long-lived token required).
# If Meta's exchange endpoint returns 429/500 repeatedly, the pipeline uses META_TOKEN as-is (warning in logs).
# META_FB_EXCHANGE=1
# Campaign-level daily insights (spend, purchases from actions/action_values). Set 0 to skip extra API + META_CAMPAIGNS sheet.
# META_CAMPAIGN_INSIGHTS=1
# Numeric ID or act_123 — script accepts both
AD_ACCOUNT_ID=

# Purchases / Purchase_Value in META_CAMPAIGNS: use ONE Meta action_type (priority list), not a sum of all
# types containing "purchase" (avoids double-count vs Ads Manager). Override order:
# META_PURCHASE_ACTION_TYPES=offsite_conversion.fb_pixel_purchase,purchase,omni_purchase
# Optional: match Ads Manager attribution columns, JSON array:
# META_ACTION_ATTRIBUTION_WINDOWS=["7d_click","1d_view"]

# Meta insights window: either lookback days from today, or explicit since/until (YYYY-MM-DD)
META_LOOKBACK_DAYS=90
# META_TIME_RANGE_SINCE=2026-01-01
# META_TIME_RANGE_UNTIL=2026-04-06

# Google Sheets — use GOOGLE_SHEET_ID or GOOGLE_SHEET_URL (recommended) and/or GOOGLE_SHEET_NAME.
# Opening by id/url needs only Sheets API + share sheet with service account (Editor).
# Opening by name needs Drive API enabled and exact file title match.
# GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# GOOGLE_SHEET_ID=SPREADSHEET_ID
GOOGLE_SHEET_NAME=Your Spreadsheet Name
GOOGLE_CREDS=creds.json
# Alternative (Vercel / CI): paste full JSON — takes precedence over GOOGLE_CREDS
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Vercel Cron: set CRON_SECRET in project env; cron calls GET /cron with Authorization: Bearer <secret>
# CRON_SECRET=

# Pipeline execution mode. Default auto rotates Vercel cron across smaller jobs.
# /cron also forces auto mode so a stale PIPELINE_MODE=full env cannot make cron run the heavy full job.
# PIPELINE_MODE=auto
# PIPELINE_ENABLE_INCREMENTAL=1
# PIPELINE_ENABLE_PARITY_CHECK=0
# PIPELINE_STATE_TAB=PIPELINE_STATE
# PIPELINE_OVERLAP_MINUTES=10
# TRACKING_ACTIVE_LOOKBACK_DAYS=30
# If Meta auth/API fails, keep Shopify/Sheets pipeline alive with empty Meta rows.
# Set 0 to fail hard on Meta errors.
# META_CONTINUE_ON_ERROR=1

# HTTP retry
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_BASE_SECONDS=1.5

# Report currency label (display) + optional USD columns: USD per 1 unit of local currency
# Example for AUD store: if 1 AUD ≈ 0.65 USD, set USD_PER_LOCAL_UNIT=0.65 (use a current rate).
# Adds Revenue_USD, Product_Cost_USD, …
# DAILY_SUMMARY tab: default 1 = only USD columns + Net_Profit (no duplicate shop currency). 0 = legacy two-column layout.
# DAILY_SUMMARY_USD_PRIMARY=1
# REPORT_CURRENCY=AUD
# USD_PER_LOCAL_UNIT=0.65
# Meta ad account currency is usually USD (Graph API "spend"). Default 1 = treat Meta spend as USD
# (Ad_Spend_USD = Ad_Spend; daily merge converts Meta USD → shop currency for ROAS using USD_PER_LOCAL_UNIT).
# Set 0 if your ad account uses the same currency as the shop (e.g. both AUD).
# META_SPEND_IN_USD=1
# SHEETS_FANCY_LAYOUT=1
# Conditional formatting in Sheets: Gross_Profit<0 (red tint), DAILY_SUMMARY Marketing_ROAS<threshold (yellow)
# SHEETS_CONDITIONAL_FORMAT=1
# Default 1.0; set 0 to disable ROAS highlighting only
# SHEETS_ROAS_WARN_BELOW=1

# If pipeline hits Sheets API 429 (writes per minute): increase pauses (seconds).
# SHEETS_PAUSE_BETWEEN_TABS_SECONDS=1.5
# SHEETS_INTER_CHUNK_PAUSE_SECONDS=0.35

# 17TRACK (optional): fills Carrier_Tracking_Status beyond Shopify. TRACK17_ENABLED=0 disables API calls
# even if TRACK17_API_KEY is set (e.g. quota exhausted or to stay under Vercel function time limits).
# TRACK17_ENABLED=0
# TRACK17_API_KEY=
# Max distinct tracking numbers per run; 0 = no cap
# TRACK17_MAX_TRACKINGS_PER_RUN=0

# Supplier unit costs: default is a Google Sheet tab named SUPPLIER_COSTS (created automatically if missing).
# Názvy sa automaticky zjednocujú aj po odseknutí koncoviek „ - farba / veľkosť“ (rovnaký model, iná varianta).
# Optional: rename tab via SUPPLIER_COSTS_SHEET_TAB=MyTab
# To use local CSV only (no Sheet tab for pipeline): SUPPLIER_COSTS_FROM_CSV=1
# SUPPLIER_COSTS_SHEET_TAB=SUPPLIER_COSTS

# BillDetail import also writes SUPPLIER_BILL_SINGLE_ORDERS (OrderNo, UnitCost, SKU, SupplierTitle) for rows
# with exactly one line on the bill — used when Shopify has a single line item but the title does not match.
# Set empty to disable: SUPPLIER_BILL_SINGLE_ORDERS_TAB=
# SUPPLIER_BILL_SINGLE_ORDERS_TAB=SUPPLIER_BILL_SINGLE_ORDERS

# Median unit cost from the previous ORDERS_DB tab when SUPPLIER_COSTS has no row (does not write back to SUPPLIER_COSTS).
# LEARN_COSTS_FROM_ORDERS_SHEET=0

# Optional «database» tab ITEM_CATALOG: columns SKU_Prefix (or Parent_SKU) + UnitCost — one wholesale price
# for all variants whose SKU starts with that prefix (same model, different color). Empty = disable tab.
# ITEM_CATALOG_SHEET_TAB=ITEM_CATALOG

# Data quality: tab listing Product+SKU where Product_Cost is 0 (no supplier unit cost matched). Logs WARNING with counts.
# Set empty to disable writing this tab: MISSING_SUPPLIER_COSTS_TAB=
# MISSING_SUPPLIER_COSTS_TAB=MISSING_SUPPLIER_COSTS

# After BillDetail upload from /app: run full pipeline automatically (default 1). Set 0 if request times out on Vercel.
# SUPPLIER_IMPORT_AUTO_PIPELINE=1

# Optional Google Sheet tab names (defaults shown)
# SHEET_TAB_ORDERS_DB=ORDERS_DB
# SHEET_TAB_ORDER_LEVEL=ORDER_LEVEL
# SHEET_TAB_META_DATA=META_DATA
# SHEET_TAB_META_CAMPAIGNS=META_CAMPAIGNS
# SHEET_TAB_DAILY_SUMMARY=DAILY_SUMMARY
# US-style monthly BOOKKEEPING: Shopify order fields (GMV, discounts, subtotal, shipping, tax, refunds)
# + COGS from line items + Meta ad spend. Not tax/legal advice.
# SHEET_TAB_BOOKKEEPING=BOOKKEEPING
# Shopify payouts transaction detail (fee/nets) used for fee-cost rollups in BOOKKEEPING.
# SHEET_TAB_PAYOUTS_FEES=PAYOUTS_FEES

# /app dashboard — reuse bundled Sheets reads for this many seconds (faster repeat loads). 0 = always fetch fresh.
# After each successful pipeline run the cache is cleared so new data shows immediately.
# DASHBOARD_BUNDLE_CACHE_SECONDS=20
# Max parallel tab reads when opening the spreadsheet once (default 10, cap 16).
# DASHBOARD_SHEET_READ_CONCURRENCY=10
# /app dashboard — executive traffic-light thresholds (JSON merges onto server defaults in api/dashboard.py).
# Keys: ROAS 30d, Gross Margin, Ad Share, Delivery Rate, Undelivered, Undelivered Now, Undelivered 30d, Avg Transit Days, Profit After Ads
# Example (partial override): DASHBOARD_EXECUTIVE_THRESHOLDS_JSON={"ROAS 30d":{"green":2.5,"amber":1.6}}
# DASHBOARD_EXECUTIVE_THRESHOLDS_JSON=
