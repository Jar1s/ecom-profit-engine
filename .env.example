# Shopify Admin API — use ONE of:
# A) Custom app static token
# SHOPIFY_STORE=your-store.myshopify.com
# SHOPIFY_TOKEN=shpat_xxx
# B) Dev Dashboard app (Client ID + Secret; token ~24h, refreshed automatically)
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional, default 2024-10
# SHOPIFY_API_VERSION=2024-10

# Meta Marketing API
# User access token with ads_read (e.g. from Graph API Explorer).
META_TOKEN=
# Optional: App ID + Secret from App settings → Basic. Each run exchanges META_TOKEN
# for a fresh long-lived token (~60d) so cron does not die when short token expires.
# META_APP_ID=
# META_APP_SECRET=
# Numeric ID or act_123 — script accepts both
AD_ACCOUNT_ID=

# Meta insights window: either lookback days from today, or explicit since/until (YYYY-MM-DD)
META_LOOKBACK_DAYS=90
# META_TIME_RANGE_SINCE=2026-01-01
# META_TIME_RANGE_UNTIL=2026-04-06

# Google Sheets (service account JSON path relative to project root)
GOOGLE_SHEET_NAME=Your Spreadsheet Name
GOOGLE_CREDS=creds.json
# Alternative (Vercel / CI): paste full JSON — takes precedence over GOOGLE_CREDS
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Vercel Cron: set CRON_SECRET in project env; cron calls GET /cron with Authorization: Bearer <secret>
# CRON_SECRET=

# HTTP retry
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_BASE_SECONDS=1.5

# Optional Google Sheet tab names (defaults shown)
# SHEET_TAB_ORDERS_DB=ORDERS_DB
# SHEET_TAB_ORDER_LEVEL=ORDER_LEVEL
# SHEET_TAB_META_DATA=META_DATA
# SHEET_TAB_DAILY_SUMMARY=DAILY_SUMMARY
